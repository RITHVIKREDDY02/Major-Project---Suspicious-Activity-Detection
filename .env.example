# Copy this file to `.env` on the EC2 server and fill in real values.
# Never commit the real .env file.

# Postgres (used by the `db` service in docker-compose)
POSTGRES_USER=sar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sardb

# Session secret for the API (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# Used by drizzle-kit when running `pnpm --filter @workspace/db run push` from the host
DATABASE_URL=postgres://sar:change-me-strong-password@localhost:5432/sardb
